# ═══════════════════════════════════════════════════════════════════════════════
# CONFIGURACIÓN DEL PUENTE SPX5 OPC UA
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# SPX5 (MODBUS TCP)
# ─────────────────────────────────────────────────────────────────────────────
SPX5_HOST=192.168.15.10
SPX5_PORT=502
SPX5_UNIT_ID=1

# ─────────────────────────────────────────────────────────────────────────────
# SERVIDOR OPC UA
# ─────────────────────────────────────────────────────────────────────────────
OPCUA_PORT=4840

# ─────────────────────────────────────────────────────────────────────────────
# API REST
# ─────────────────────────────────────────────────────────────────────────────
API_PORT=3000

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# http://localhost:3000/api-docs

# ─────────────────────────────────────────────────────────────────────────────
# POSTGRESQL
# ─────────────────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_ADMIN_USER=tesis
DB_ADMIN_PASS=tesis
DB_USER=tesis
DB_PASSWORD=tesis
DB_NAME=postgres
